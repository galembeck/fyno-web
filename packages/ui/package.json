{
  "name": "@fyno/ui",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "check-types": "tsc --noEmit",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./styles.css": "./dist/index.css",
    "./theme-cpfl-total.css": "./src/theme-cpfl-total.css",
    "./theme-alesta.css": "./src/theme-alesta.css",
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@fyno/eslint-config": "workspace:*",
    "@fyno/tailwind-config": "workspace:*",
    "@fyno/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.1.5",
    "@types/react": "^19.1.0",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.1.5",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@sentry/react": "^10.0.0",
    "@tanstack/react-router": "^1.157.16",
    "@types/react-dom": "^19.2.3",
    "clsx": "^2.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "react-dom": "^19.2.0",
    "react-google-recaptcha-v3": "^1.11.0",
    "react-hook-form": "^7.71.1",
    "react-hot-toast": "^2.6.0",
    "react-select": "^5.10.2",
    "swiper": "11.1.4",
    "tailwind-merge": "^3.4.0",
    "yup": "^1.7.1"
  }
}
